# ============================================================
# Datastream Books .gitignore
# Covers: Dataverse solutions, .NET plugins, PCF/React, PowerShell,
#         Windows/IDE noise, secrets
# ============================================================

# ============================================================
# Secrets & Local Config (NEVER COMMIT)
# ============================================================
*.env
.env
.env.*
*.secret
*.secrets
secrets.json
appsettings.local.json
appsettings.Development.json
local.settings.json
**/connectionstrings.json
**/credentials.json
*.pfx
*.p12
*.key
*.pem
.pac/
.user

